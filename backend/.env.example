# Copie para .env e ajuste. O .env NÃO vai pro git.

# --- Banco (bate com o docker-compose) ---
# Porta 5000 no host (não 5432) para evitar conflito com um Postgres
# já instalado na máquina. Se sua máquina não tem esse conflito e prefere
# 5432, troque aqui E no docker-compose.yml (ports) ao mesmo tempo.
DATABASE_URL=postgresql://hub:hub@localhost:5000/hub_agentes

# --- LLM (OpenAI) ---
# Precisa de uma chave válida pra gerar o relatório mensal do Financeiro
# (POST /financeiro/relatorio/gerar). Upload e dashboard não usam LLM.
OPENAI_API_KEY=
# Modelo barato roda a maioria dos ticks (decisão de ação).
LLM_MODEL_CHEAP=gpt-4o-mini
# Modelo forte: execução real e o relatório mensal do Financeiro.
LLM_MODEL_STRONG=gpt-4o

# --- Custo do modelo forte (USD por 1K tokens) ---
# Usado só pra estimar custo_usd nos relatórios gerados. CONFERIR na página
# de pricing da OpenAI antes de confiar nesse número — pode estar desatualizado.
PRECO_INPUT_POR_1K_FORTE=0.0025
PRECO_OUTPUT_POR_1K_FORTE=0.01

# --- Custo do modelo barato (USD por 1K tokens) ---
# Usado na estimativa de macro de refeição do agente de Saúde. CONFERIR
# também antes de confiar.
PRECO_INPUT_POR_1K_BARATO=0.00015
PRECO_OUTPUT_POR_1K_BARATO=0.0006

# --- Motor de tick ---
# A cada quantos minutos REAIS dispara um tick.
TICK_INTERVALO_MIN=15
# Quantos minutos SIMULADOS cada tick avança no relógio do escritório.
TICK_MINUTOS_SIMULADOS=60

# --- Controle de custo ---
# Teto de gasto por dia (USD). Estourou -> o relógio pausa sozinho.
ORCAMENTO_DIARIO_USD=1.0

# --- Contexto ---
# Teto de tokens do pacote de contexto montado por tick, por agente.
CONTEXTO_MAX_TOKENS=2000

# --- GitHub (agente Norte) ---
# OAuth App com "Device Flow" habilitado (github.com/settings/developers).
# Device Flow só precisa do client_id, não usa client_secret.
GITHUB_CLIENT_ID=
GITHUB_OAUTH_SCOPE=repo
